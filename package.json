{
  "name": "harness",
  "description": "Extensible CLI harness for running configurable AI coding agents",
  "version": "0.1.0",
  "author": "Hesed",
  "bin": {
    "ai": "./bin/run.js"
  },
  "bugs": "https://github.com/hesedcasa/harness/issues",
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.79.1",
    "@earendil-works/pi-ai": "^0.79.1",
    "@earendil-works/pi-coding-agent": "^0.79.1",
    "@hesed/plugin-lib": "^0.9.0",
    "@oclif/core": "^4"
  },
  "devDependencies": {
    "@eslint/compat": "^1",
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/chai": "^4",
    "@types/mocha": "^10",
    "@types/node": "^18",
    "chai": "^4",
    "eslint": "^9",
    "eslint-config-oclif": "^6",
    "eslint-config-prettier": "^10",
    "mocha": "^11",
    "oclif": "^4",
    "prettier": "^3.8.1",
    "shx": "^0.3.3",
    "ts-node": "^10",
    "ts-prune": "^0.10.3",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "homepage": "https://github.com/hesedcasa/harness",
  "keywords": [
    "agent",
    "ai",
    "harness",
    "oclif",
    "pi"
  ],
  "license": "Apache 2.0",
  "main": "dist/index.js",
  "type": "module",
  "oclif": {
    "bin": "ai",
    "dirname": "ai",
    "commands": "./dist/commands",
    "topicSeparator": " ",
    "topics": {
      "lsp": {
        "description": "Inspect language-server support"
      },
      "profile": {
        "description": "Manage LLM provider profiles"
      },
      "skills": {
        "description": "Manage reusable agent skills"
      },
      "tools": {
        "description": "Inspect and call harness tools"
      },
      "workspace": {
        "description": "Manage local and sandbox workspaces"
      }
    }
  },
  "repository": "hesedcasa/harness",
  "scripts": {
    "build": "shx rm -rf dist && tsc -b",
    "lint": "eslint",
    "postpack": "shx rm -f oclif.manifest.json",
    "posttest": "npm run lint",
    "prepack": "oclif manifest && oclif readme",
    "test": "mocha --forbid-only \"test/**/*.test.ts\"",
    "version": "oclif readme && git add README.md",
    "find-deadcode": "ts-prune --ignore '(run|default)'",
    "format": "eslint --cache --fix --quiet . && prettier --write --cache .",
    "pre-commit": "npm run format && npm run find-deadcode"
  },
  "types": "dist/index.d.ts"
}
